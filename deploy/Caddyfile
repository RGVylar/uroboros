# Uroboros — reverse proxy + static frontend
# Listens on all IPs on port 80 (ideal for local network or behind Cloudflare Tunnel)

:80 {
	encode gzip

	# API — note: use 'handle', not 'handle_path', to preserve /api prefix
	handle /api/* {
		reverse_proxy 127.0.0.1:__BACKEND_PORT__
	}

	# Static SvelteKit build (adapter-static output)
	handle {
		root * __APP_DIR__/frontend/build
		try_files {path} /index.html
		file_server
	}
}
